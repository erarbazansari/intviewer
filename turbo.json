{
    "$schema": "https://turborepo.dev/schema.json",
    "globalEnv": ["ENVIRONMENT", "PORT", "BACKEND_SERVER_URL", "NODE_ENV"],
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "check-types": {
            "dependsOn": ["^check-types"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}
